# ─── App ──────────────────────────────────────────────
APP_NAME="Real Estate AI Agent"
ENV=development
CORS_ORIGINS=["http://localhost:3000"]

# ─── Adapter flags (mock-first) ───────────────────────
USE_MOCKS=true
USE_REAL_SUPABASE=false
USE_REAL_LINE=false
USE_REAL_AI=false

# ─── Secrets (placeholders — replace before prod) ─────
JWT_SECRET=change-me-in-production
LINE_CHANNEL_SECRET=change-me
LINE_CHANNEL_ACCESS_TOKEN=change-me
ANTHROPIC_API_KEY=change-me
GEMINI_API_KEY=change-me
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=change-me
SUPABASE_SERVICE_ROLE_KEY=change-me

# ─── Mock storage ─────────────────────────────────────
VAR_DIR=var

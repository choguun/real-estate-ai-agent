# ─── App ──────────────────────────────────────────────
APP_NAME="Real Estate AI Agent"
ENV=development
# CORS_ORIGINS: required, must NOT be ["*"] in production.
# Example: CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]
CORS_ORIGINS=["http://localhost:3000"]

# ─── Adapter flags (mock-first) ───────────────────────
USE_MOCKS=true
USE_REAL_SUPABASE=false
USE_REAL_LINE=false
USE_REAL_AI=false

# ─── Secrets (placeholders — replace before prod) ─────
# JWT_SECRET: required in production, ≥32 bytes, NOT the dev default.
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(64))'
JWT_SECRET=change-me-in-production
# JWT_SECRET_PREVIOUS: OPTIONAL — set during the secret-rotation
# rollover window. Empty = no rotation in progress. ≥32 bytes when
# set in production. See docs/security.md for the rotation playbook.
JWT_SECRET_PREVIOUS=
# LINE_CHANNEL_SECRET: required in production, NOT the dev default.
LINE_CHANNEL_SECRET=change-me
LINE_CHANNEL_ACCESS_TOKEN=change-me
LINE_DEFAULT_AGENT_ID=
ANTHROPIC_API_KEY=change-me
GEMINI_API_KEY=change-me
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=change-me
SUPABASE_SERVICE_ROLE_KEY=change-me

# ─── Mock storage ─────────────────────────────────────
VAR_DIR=var
PUBLIC_BASE_URL=http://localhost:8000

# ─── Stripe (real-mode billing, T-405) ─────────────────
# Set USE_MOCKS=false + these 4 vars to enable real Stripe.
# Get test keys at https://dashboard.stripe.com/test/apikeys
# Get price IDs from your Stripe dashboard after creating products.
STRIPE_API_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder
STRIPE_PRICE_GROWTH=price_growth_placeholder
STRIPE_PRICE_TEAM=price_team_placeholder

# ─── MFA (cycle 8 T-801) ──────────────────────────────────────────
# MFA_ENCRYPTION_KEY: 32-byte URL-safe base64-encoded Fernet key
# used to encrypt TOTP secrets at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Empty = MFA disabled (dev/test only).
MFA_ENCRYPTION_KEY=
